# ═══════════════════════════════════════════════════
# ZOLT Environment Variables
# Copy this to .env and populate with your keys
# ═══════════════════════════════════════════════════

# ── OpenRouter API ────────────────────────────────# LLM Provider Configuration (OpenRouter by default)
API_BASE_URL=https://openrouter.ai/api/v1/chat/completions
API_KEY=your_openrouter_api_key_here
MODEL=deepseek/deepseek-r1:free

# Local Ollama Config Example:
# API_BASE_URL=http://host.docker.internal:11434/v1/chat/completions
# API_KEY=ollama
# MODEL=llama3
# ── GitHub MCP Server ─────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token_here

# ── Google Drive MCP Server (optional) ────────────
# GOOGLE_SERVICE_ACCOUNT_KEY=path/to/service-account.json

# ── Database ──────────────────────────────────────
ZOLT_DB_PATH=data/zolt_evals.db
